{
  "name": "bladerunner",
  "private": true,
  "version": "0.10.228",
  "description": "Bladerunner by Edgehealth — Operational control surface for validating application experiences",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web:delayed": "wait-on tcp:127.0.0.1:3001 && pnpm run dev:web",
    "dev:web": "pnpm --filter @bladerunner/web dev",
    "dev:api": "pnpm --filter @bladerunner/api dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @bladerunner/web build",
    "build:api": "pnpm --filter @bladerunner/api build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r run typecheck",
    "check:db-tcp": "node --env-file=.env scripts/check-db-tcp.mjs",
    "migrate:api": "pnpm --filter @bladerunner/api run migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "mailslurp:list-inboxes": "node scripts/mailslurp-list-inboxes.mjs",
    "repro:clerk-stale-token": "node --env-file=.env scripts/repro-clerk-stale-token.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@prisma/client"
    ]
  },
  "devDependencies": {
    "@bladerunner/clerk-agentmail-signin": "workspace:*",
    "@clerk/testing": "^2.0.5",
    "@playwright/test": "^1.58.2",
    "mailslurp-client": "^17.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "wait-on": "^9.0.4",
    "tree-kill": "^1.2.2"
  }
}
