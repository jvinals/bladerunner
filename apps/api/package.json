{
  "name": "@bladerunner/api",
  "version": "0.6.205",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @bladerunner/clerk-agentmail-signin run build && prisma generate",
    "build": "nest build",
    "predev": "pnpm --filter @bladerunner/clerk-agentmail-signin run build && prisma generate",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "start": "nest start",
    "dev": "rm -f tsconfig.tsbuildinfo && nest start --watch",
    "start:dev": "pnpm run dev",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "test:playback-skip": "tsx src/modules/recording/playback-skip.selftest.ts",
    "test:playback-css": "tsx src/modules/recording/playback-css-escape.selftest.ts",
    "test:clerk-canonical": "tsx src/modules/recording/recording-clerk-canonical-steps.selftest.ts",
    "test:playback-chain": "tsx src/modules/recording/playback-execution-chain.selftest.ts",
    "test:clerk-auto-signin-metadata": "tsx src/modules/recording/clerk-auto-sign-in-step-metadata.selftest.ts",
    "test:recording-merge": "tsx src/modules/recording/recording-playwright-merge.selftest.ts",
    "test:optimized-prompt-recording": "tsx src/modules/recording/optimized-prompt.selftest.ts",
    "test:ai-visual-id": "tsx src/modules/recording/ai-visual-id.selftest.ts",
    "test:resume-recording": "tsx src/modules/recording/resume-recording.selftest.ts",
    "test:optimized-prompt-llm": "tsx src/modules/llm/optimized-prompt.selftest.ts",
    "test:recorded-playwright": "tsx src/modules/recording/recorded-playwright.selftest.ts",
    "test:recording-timeout": "tsx src/modules/recording/recording-timeout.selftest.ts",
    "test:llm-suggest-skip": "tsx src/modules/llm/llm-suggest-skip.selftest.ts",
    "test:gemini-instruction": "tsx src/modules/llm/gemini-instruction.selftest.ts",
    "test:discovery-navigation-tree": "tsx src/modules/projects/discovery-navigation-tree.selftest.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@bladerunner/clerk-agentmail-signin": "workspace:*",
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@playwright/test": "1.58.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "pg-connection-string": "^2.12.0",
    "playwright-core": "1.58.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
