datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RunStatus {
  RECORDING
  COMPLETED
  FAILED
  CANCELLED
}

enum Platform {
  DESKTOP
  MOBILE
  PWA
}

/// Target for recording: web URL or mobile app reference.
enum ProjectKind {
  WEB
  IOS
  ANDROID
}

enum StepAction {
  NAVIGATE
  CLICK
  TYPE
  SCROLL
  SELECT
  HOVER
  SCREENSHOT
  ASSERT
  WAIT
  CUSTOM
}

enum StepOrigin {
  MANUAL
  AI_DRIVEN
  AUTOMATIC
}

model Project {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  name        String
  kind        ProjectKind @default(WEB)
  /// Web app URL, or store / deeplink for mobile
  url         String?
  /// APK / IPA / build artifact URL or download link
  artifactUrl String?     @map("artifact_url")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  runs Run[]

  @@index([userId])
  @@map("projects")
}

model Run {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  projectId   String?   @map("project_id")
  name        String
  url         String
  status      RunStatus @default(RECORDING)
  platform    Platform  @default(DESKTOP)
  durationMs  Int?      @map("duration_ms")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  /// API path for list thumbnails, e.g. `/api/runs/:id/recording/thumbnail` (set when session video is saved).
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project    Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  steps      RunStep[]
  recordings RunRecording[]

  @@index([userId])
  @@index([projectId])
  @@map("runs")
}

model RunStep {
  id             String     @id @default(uuid())
  runId          String     @map("run_id")
  userId         String     @map("user_id")
  sequence       Int
  action         StepAction
  selector       String?
  value          String?
  instruction    String
  playwrightCode String     @map("playwright_code")
  origin         StepOrigin @default(MANUAL)
  durationMs     Int?       @map("duration_ms")
  timestamp      DateTime
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([userId])
  @@map("run_steps")
}

model RunRecording {
  id        String   @id @default(uuid())
  runId     String   @map("run_id")
  userId    String   @map("user_id")
  format    String   @default("webm")
  url       String?
  sizeBytes Int?     @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_recordings")
}
