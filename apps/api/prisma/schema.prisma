datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

enum RunStatus {
  RECORDING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum Platform {
  DESKTOP
  MOBILE
  PWA
}

/// Target for recording: web URL or mobile app reference.
enum ProjectKind {
  WEB
  IOS
  ANDROID
}

enum TestEmailProvider {
  MAILSLURP
  CLERK_TEST_EMAIL
}

enum StepAction {
  NAVIGATE
  CLICK
  TYPE
  SCROLL
  SELECT
  HOVER
  SCREENSHOT
  ASSERT
  WAIT
  CUSTOM
}

enum StepOrigin {
  MANUAL
  AI_DRIVEN
  /// Prompt-only step: playback runs LLM + vision against live DOM each time (not stored Playwright).
  AI_PROMPT
  AUTOMATIC
}

model Project {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  name        String
  kind        ProjectKind @default(WEB)
  /// Web app URL, or store / deeplink for mobile
  url         String?
  /// APK / IPA / build artifact URL or download link
  artifactUrl        String?            @map("artifact_url")
  /// Hex color for UI display, e.g. "#4B90FF"
  color              String             @default("#4B90FF")
  /// Email for automated test sign-in
  testUserEmail      String?            @map("test_user_email")
  /// Password for automated test sign-in
  testUserPassword   String?            @map("test_user_password")
  /// Email provider used for OTP retrieval during test sign-in
  testEmailProvider  TestEmailProvider? @map("test_email_provider")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  runs        Run[]
  evaluations Evaluation[]

  @@index([userId])
  @@map("projects")
}

model Run {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  projectId   String?   @map("project_id")
  name        String
  url         String
  status      RunStatus @default(RECORDING)
  platform    Platform  @default(DESKTOP)
  recordingViewportWidth  Int @default(1280) @map("recording_viewport_width")
  recordingViewportHeight Int @default(720) @map("recording_viewport_height")
  streamMaxWidth          Int @default(1280) @map("stream_max_width")
  streamMaxHeight         Int @default(720) @map("stream_max_height")
  streamJpegQuality       Int @default(60) @map("stream_jpeg_quality")
  streamEveryNthFrame     Int @default(1) @map("stream_every_nth_frame")
  durationMs  Int?      @map("duration_ms")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  /// API path for list thumbnails, e.g. `/api/runs/:id/recording/thumbnail` (set when session video is saved).
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  steps       RunStep[]
  recordings  RunRecording[]
  checkpoints RunCheckpoint[]
  aiVisualIdTests AiVisualIdTest[]

  @@index([userId])
  @@index([projectId])
  @@map("runs")
}

model AiVisualIdTest {
  id             String   @id @default(uuid())
  runId          String   @map("run_id")
  userId         String   @map("user_id")
  stepSequence   Int      @map("step_sequence")
  provider       String
  model          String
  prompt         String
  answer         String
  pageUrl        String?  @map("page_url")
  screenshotPath String   @map("screenshot_path")
  contextPath    String   @map("context_path")
  createdAt      DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_visual_id_tests")
}

/// Captured browser storage (cookies / localStorage) after a step — optional aid for “app state” restore; prefix replay remains the source of truth for determinism.
model RunCheckpoint {
  id                 String   @id @default(uuid())
  runId              String   @map("run_id")
  userId             String   @map("user_id")
  /// State snapshot after this step sequence (before the next step).
  afterStepSequence  Int      @map("after_step_sequence")
  label              String   @default("")
  pageUrl            String?  @map("page_url")
  /// File name under the run artifact dir, e.g. `checkpoint-3.json`
  storageStatePath   String?  @map("storage_state_path")
  /// JPEG thumbnail file name, e.g. `checkpoint-3.jpg`
  thumbnailPath      String?  @map("thumbnail_path")
  createdAt          DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([userId])
  @@map("run_checkpoints")
}

model RunStep {
  id             String     @id @default(uuid())
  runId          String     @map("run_id")
  userId         String     @map("user_id")
  sequence       Int
  action         StepAction
  selector       String?
  value          String?
  instruction    String
  playwrightCode String     @map("playwright_code")
  recordedPlaywrightCode String? @map("recorded_playwright_code")
  origin         StepOrigin @default(MANUAL)
  durationMs     Int?       @map("duration_ms")
  timestamp      DateTime
  metadata       Json?
  /// When true, playback skips this step (still listed in the UI; soft “delete” from replay).
  excludedFromPlayback Boolean @default(false) @map("excluded_from_playback")
  createdAt      DateTime   @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([userId])
  @@map("run_steps")
}

model RunRecording {
  id        String   @id @default(uuid())
  runId     String   @map("run_id")
  userId    String   @map("user_id")
  format    String   @default("webm")
  url       String?
  sizeBytes Int?     @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_recordings")
}

/// Per-user LLM routing (provider + model id per usage key).
model UserLlmPreferences {
  userId          String   @id @map("user_id")
  preferencesJson Json     @map("preferences_json")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_llm_preferences")
}

/// Per-user encrypted LLM credentials (AES-256-GCM). Plaintext JSON shape: Record<providerId, { apiKey?: string, baseUrl?: string }>.
model UserLlmCredentials {
  userId            String   @id @map("user_id")
  payloadEncrypted  Bytes    @map("payload_encrypted")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_llm_credentials")
}

/// Autonomous app exploration / reporting (separate from recording `Run`).
enum EvaluationStatus {
  QUEUED
  RUNNING
  WAITING_FOR_HUMAN
  COMPLETED
  FAILED
  CANCELLED
}

enum EvaluationStepDecision {
  retry
  advance
  ask_human
  finish
}

model Evaluation {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  projectId        String?           @map("project_id")
  name             String            @default("Evaluation")
  url              String
  intent           String            @db.Text
  desiredOutput    String            @map("desired_output") @db.Text
  progressSummary  String?           @map("progress_summary") @db.Text
  status           EvaluationStatus  @default(QUEUED)
  startedAt        DateTime?         @map("started_at")
  completedAt      DateTime?         @map("completed_at")
  failureMessage   String?           @map("failure_message") @db.Text
  /// When true, the evaluation browser attempts the same Clerk / project test-user sign-in as playback when a sign-in page is detected.
  autoSignIn                Boolean  @default(false) @map("auto_sign_in")
  /// Clerk OTP path when `autoSignIn` is true and the page uses Clerk (`mailslurp` | `clerk_test_email`). Null = server default (`PLAYBACK_CLERK_OTP_MODE`).
  autoSignInClerkOtpMode    String?  @map("auto_sign_in_clerk_otp_mode")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  steps     EvaluationStep[]
  questions EvaluationQuestion[]
  reports   EvaluationReport[]

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId])
  @@map("evaluations")
}

model EvaluationStep {
  id                String                  @id @default(uuid())
  evaluationId      String                  @map("evaluation_id")
  userId            String                  @map("user_id")
  sequence          Int
  pageUrl           String?                 @map("page_url")
  thinkingText      String?                 @map("thinking_text") @db.Text
  proposedCode      String?                 @map("proposed_code") @db.Text
  expectedOutcome   String?                 @map("expected_outcome") @db.Text
  actualOutcome     String?                 @map("actual_outcome") @db.Text
  errorMessage      String?                 @map("error_message") @db.Text
  decision          EvaluationStepDecision?
  analyzerRationale String?                 @map("analyzer_rationale") @db.Text
  createdAt         DateTime                @default(now()) @map("created_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId, sequence])
  @@map("evaluation_steps")
}

model EvaluationQuestion {
  id             String    @id @default(uuid())
  evaluationId String      @map("evaluation_id")
  userId         String      @map("user_id")
  stepSequence   Int?        @map("step_sequence")
  prompt         String      @db.Text
  /// JSON string array of 3–4 option labels
  optionsJson    String      @map("options_json") @db.Text
  state          String      @default("pending")
  selectedIndex  Int?        @map("selected_index")
  createdAt      DateTime    @default(now()) @map("created_at")
  answeredAt     DateTime?   @map("answered_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@map("evaluation_questions")
}

model EvaluationReport {
  id              String   @id @default(uuid())
  evaluationId    String   @map("evaluation_id")
  userId          String   @map("user_id")
  format          String   @default("markdown")
  content         String   @db.Text
  structuredJson  Json?    @map("structured_json")
  createdAt       DateTime @default(now()) @map("created_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@map("evaluation_reports")
}
