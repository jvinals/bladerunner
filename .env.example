# ─── Bladerunner Environment Configuration ────────────────────────────────────

# Backend
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/railway

# Frontend (REST + Socket.IO for live recording frames — must match API origin)
VITE_API_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
# API + Playwright / @clerk/testing (same Clerk instance as VITE_CLERK_PUBLISHABLE_KEY)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
# Optional: when recording/playing back a **different** product (e.g. Evocare) than Bladerunner, put **that**
# app’s Clerk **secret** here so auto sign-in can mint testing tokens. Bladerunner UI auth still uses CLERK_SECRET_KEY above.
# PLAYBACK_CLERK_SECRET_KEY=sk_test_other-app-clerk-secret
# (alias) E2E_CLERK_SECRET_KEY=sk_test_other-app-clerk-secret

# E2E (pnpm test:e2e): pick ONE sign-in method
# A) Ticket sign-in (no password): user must exist in your Clerk dev instance
# E2E_CLERK_USER_EMAIL=test-user@your-domain.com
#
# B) Password only (no email 2FA): set identifier + password (omit AgentMail vars below)
# E2E_CLERK_USER_EMAIL=test-user@your-domain.com
# E2E_CLERK_USER_PASSWORD=your-test-password
#
# C) Password + email OTP (e.g. Clerk 2FA delivered to AgentMail): set password + identifier
#    (email in E2E_CLERK_USER_EMAIL or E2E_CLERK_USER_USERNAME) AND:
AGENTMAIL_API_KEY=
# Inbox: set ONE of these (dashboard often hides the id — use your address or run `pnpm agentmail:list-inboxes`)
# E2E_AGENTMAIL_INBOX_EMAIL=evocare@agentmail.to
# E2E_AGENTMAIL_INBOX_ID=

# Optional override (default http://127.0.0.1:5173)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173

# Playback (API): auto Clerk + AgentMail sign-in when Clerk UI appears (same env as E2E password + OTP)
# When true, steps recorded with metadata.clerkAuthPhase are skipped during replay; optional overrides: POST body autoClerkSignIn / skipUntilSequence / skipStepIds
# PLAYBACK_AUTO_CLERK_SIGNIN=true

# Browser Worker (Docker)
BROWSER_WORKER_URL=ws://localhost:3002

# LLM Provider (configurable: "openai" or "anthropic")
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
