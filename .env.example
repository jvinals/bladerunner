# ─── Bladerunner Environment Configuration ────────────────────────────────────

# Backend
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/railway

# Settings → AI/LLM: saving provider API keys to PostgreSQL requires AES encryption (32 bytes, base64).
# Generate: openssl rand -base64 32
# Must use KEY=value (equals sign). Example: LLM_CREDENTIALS_ENCRYPTION_KEY=paste-openssl-output-here

# Frontend — omit `VITE_API_URL` in local dev so requests use `/api` (Vite proxies to the API on 3001).
# If you set it (recording Socket.IO / direct API), prefer `http://127.0.0.1:3001` over `localhost` to avoid IPv6 mismatch "Failed to fetch".
# VITE_API_URL=http://127.0.0.1:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
# API + Playwright / @clerk/testing (same Clerk instance as VITE_CLERK_PUBLISHABLE_KEY)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
# Optional: when recording/playing back a **different** product (e.g. Evocare) than Bladerunner, put **that**
# app’s Clerk **secret** here so auto sign-in can mint testing tokens. Bladerunner UI auth still uses CLERK_SECRET_KEY above.
# PLAYBACK_CLERK_SECRET_KEY=sk_test_other-app-clerk-secret
# (alias) E2E_CLERK_SECRET_KEY=sk_test_other-app-clerk-secret
#
# If Clerk Frontend API traffic uses a different hostname than `CLERK_FAPI` (proxy / satellite / custom domain),
# list extra hosts (comma-separated, no protocol), and/or override the host used for testing tokens:
# CLERK_FAPI_EXTRA_HOSTS=clerk.yourproduct.com,other.proxy.example
# CLERK_TESTING_FRONTEND_API_URL=clerk.yourproduct.com

# E2E (pnpm test:e2e): pick ONE sign-in method
# A) Ticket sign-in (no password): user must exist in your Clerk dev instance
# E2E_CLERK_USER_EMAIL=test-user@your-domain.com
#
# B) Password only (no email 2FA): set identifier + password (omit MailSlurp vars below)
# E2E_CLERK_USER_EMAIL=test-user@your-domain.com
# E2E_CLERK_USER_PASSWORD=your-test-password
#
# C) Password + email OTP (Clerk sends code to your MailSlurp inbox): set password + identifier
#    (email in E2E_CLERK_USER_EMAIL or E2E_CLERK_USER_USERNAME) AND:
# API key from https://app.mailslurp.com → API Keys
MAILSLURP_API_KEY=
# Inbox: set ONE of — UUID from dashboard, OR full inbox email (resolved via getInboxes)
# MAILSLURP_INBOX_EMAIL=xxxx@mailslurp.biz
# MAILSLURP_INBOX_ID=
# List inboxes: `pnpm mailslurp:list-inboxes` / `npm run mailslurp:list-inboxes`

# Optional override (default http://127.0.0.1:5173)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173

# Playback (API): auto Clerk + MailSlurp sign-in when Clerk UI appears (same env as E2E password + OTP)
# When true, steps recorded with metadata.clerkAuthPhase are skipped during replay; optional overrides: POST body autoClerkSignIn / skipUntilSequence / skipStepIds
# PLAYBACK_AUTO_CLERK_SIGNIN=true

# Clerk OTP during auto sign-in (playback + recording Sign in automatically). Default when unset: mailslurp (needs MAILSLURP_*). Use clerk_test_email for +clerk_test / 424242 without MailSlurp.
# PLAYBACK_CLERK_OTP_MODE=mailslurp

# Browser Worker (Docker)
BROWSER_WORKER_URL=ws://localhost:3002

# LLM Provider (configurable: "openai" or "anthropic")
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Autonomous evaluations — speed tuning (optional; sensible defaults are set in code)
# Faster vision model for evaluation codegen + analyzer only (defaults to gemini-2.0-flash when unset).
# Users with Settings → LLM overrides per usage key still win when configured.
# EVALUATION_VISION_MODEL=gemini-2.0-flash
# GEMINI_EVALUATION_MODEL=gemini-2.0-flash
# GEMINI_INSTRUCTION_MODEL=gemini-3-flash-preview
#
# Per-step timeouts (ms): Playwright locator waits; LLM abort if the model hangs
# EVALUATION_PLAYWRIGHT_TIMEOUT_MS=15000
# EVALUATION_CODEGEN_TIMEOUT_MS=120000
# (Removed) EVALUATION_ANALYZER_TIMEOUT_MS — no evaluation_analyzer LLM; continuation is deterministic.
#
# Deploy API + LLM in the same region as your Gemini/OpenAI endpoint to cut network latency.
